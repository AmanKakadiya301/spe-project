# ─────────────────────────────────────────────────────────────────────────────
# Environment Variables Template
# Copy this file to .env and fill in the actual secure values.
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Flask Application Settings
FLASK_ENV=development
PORT=5000
APP_VERSION=1.0.0-dev

# Security Keys (Generate a strong random string for production)
# e.g., python -c 'import secrets; print(secrets.token_hex(32))'
FLASK_SECRET_KEY=dev-secret-change-in-prod-1a2b3c4d5e

# External APIs (Optional - if missing, app falls back to simulation)
# YFINANCE_API_KEY=your_api_key_here

# Kubernetes / Docker Info (Used by CD pipeline, usually injected via secrets)
# DOCKERHUB_USERNAME=your_username
# KUBECONFIG_BASE64=your_base64_kubeconfig
