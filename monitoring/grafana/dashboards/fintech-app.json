{
  "title": "AutoDevOps FinTech — App Metrics",
  "uid": "fintech-app-v2",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1, "type": "stat", "title": "App Status",
      "gridPos": {"x":0,"y":0,"w":4,"h":4},
      "targets": [{"expr": "up{job=\"stock-app\"}", "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [
        {"type":"value","options":{"0":{"text":"DOWN","color":"red"},"1":{"text":"UP","color":"green"}}}
      ]}}
    },
    {
      "id": 2, "type": "stat", "title": "Request Rate (req/s)",
      "gridPos": {"x":4,"y":0,"w":4,"h":4},
      "targets": [{"expr": "sum(rate(flask_http_request_total[1m]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps", "decimals": 2}}
    },
    {
      "id": 3, "type": "stat", "title": "Error Rate %",
      "gridPos": {"x":8,"y":0,"w":4,"h":4},
      "targets": [{"expr": "sum(rate(flask_http_request_total{status=~\"5..\"}[5m])) / sum(rate(flask_http_request_total[5m])) * 100", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 2,
        "thresholds": {"steps": [{"value":0,"color":"green"},{"value":1,"color":"yellow"},{"value":5,"color":"red"}]}}}
    },
    {
      "id": 4, "type": "stat", "title": "p95 Latency",
      "gridPos": {"x":12,"y":0,"w":4,"h":4},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(flask_http_request_duration_seconds_bucket[5m])) by (le))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 3,
        "thresholds": {"steps": [{"value":0,"color":"green"},{"value":0.5,"color":"yellow"},{"value":2,"color":"red"}]}}}
    },
    {
      "id": 5, "type": "timeseries", "title": "Requests by Status Code",
      "gridPos": {"x":0,"y":4,"w":12,"h":8},
      "targets": [
        {"expr": "sum(rate(flask_http_request_total{status=~\"2..\"}[1m])) by (status)", "legendFormat": "2xx {{status}}", "refId": "A"},
        {"expr": "sum(rate(flask_http_request_total{status=~\"4..\"}[1m])) by (status)", "legendFormat": "4xx {{status}}", "refId": "B"},
        {"expr": "sum(rate(flask_http_request_total{status=~\"5..\"}[1m])) by (status)", "legendFormat": "5xx {{status}}", "refId": "C"}
      ]
    },
    {
      "id": 6, "type": "timeseries", "title": "Response Latency Percentiles",
      "gridPos": {"x":12,"y":4,"w":12,"h":8},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(flask_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum(rate(flask_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum(rate(flask_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 7, "type": "timeseries", "title": "Top 10 Endpoints",
      "gridPos": {"x":0,"y":12,"w":24,"h":8},
      "targets": [
        {"expr": "topk(10, sum(rate(flask_http_request_total[5m])) by (method,path))", "legendFormat": "{{method}} {{path}}", "refId": "A"}
      ]
    }
  ]
}
